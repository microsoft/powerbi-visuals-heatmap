{
    "compilerOptions": {
        "allowJs": false,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "module": "es6",
        "target": "es6",
        "sourceMap": true,
        "outDir": "../.tmp/build/",
        "moduleResolution": "node",
        "declaration": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "types": ["jasmine"]
    },
    "include": [
        "./**/*.ts"
    ]
}
